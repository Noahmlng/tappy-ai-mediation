{
  "name": "@ai-network/tappy-ai-mediation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "validate:schemas": "echo 'Schema validation hooks will be added in phase 1 implementation.'",
    "db:migrate": "node --env-file-if-exists=.env ./scripts/db-migrate.js",
    "db:migrate:dry-run": "node --env-file-if-exists=.env ./scripts/db-migrate.js --dry-run",
    "db:migrate:status": "node --env-file-if-exists=.env ./scripts/db-migrate.js --status",
    "check:env": "node --env-file-if-exists=.env ./src/config/check-env.js",
    "check:managed-services": "node --env-file-if-exists=.env ./scripts/check-managed-services.js",
    "test:contracts": "node --test ./tests/contracts/**/*.spec.js",
    "test:integration": "node ./scripts/run-integration-tests.js",
    "test:e2e": "node ./scripts/test-db-cleanup.js && node --test ./tests/e2e/**/*.spec.js",
    "test:functional:p0": "npm run test:contracts && npm run test:integration && npm run test:e2e",
    "perf:sdk-batch": "node --env-file-if-exists=.env ./scripts/perf-sdk-batch.js",
    "meyka:suite": "node --env-file-if-exists=.env ./scripts/run-meyka-suite.js",
    "regress:meyka": "node --env-file-if-exists=.env ./scripts/regress-meyka-closure.js",
    "smoke:ads": "node ./scripts/smoke-ads-runtime.js --mode=mock",
    "smoke:ads:live": "node --env-file-if-exists=.env ./scripts/smoke-ads-runtime.js --mode=live",
    "e2e:next-step": "node ./scripts/e2e-next-step-scenarios.js",
    "dev:gateway": "MEDIATION_ENABLE_LOCAL_SERVER=true node --env-file-if-exists=.env ./src/devtools/mediation/mediation-gateway.js",
    "dev:gateway:watch": "MEDIATION_ENABLE_LOCAL_SERVER=true node --env-file-if-exists=.env --watch ./src/devtools/mediation/mediation-gateway.js",
    "house-ads:build-search-jobs": "node ./scripts/house-ads/build-search-jobs.js",
    "house-ads:merge-search-results": "node ./scripts/house-ads/merge-search-results.js",
    "house-ads:verify-brand-domain": "node ./scripts/house-ads/verify-brand-domain.js",
    "house-ads:crawl-brand-pages": "node ./scripts/house-ads/crawl-brand-pages.js",
    "house-ads:generate-creatives": "node ./scripts/house-ads/generate-creatives.js",
    "house-ads:qa-and-publish": "node ./scripts/house-ads/qa-and-publish.js",
    "house-ads:bootstrap-500": "npm run house-ads:build-search-jobs && npm run house-ads:merge-search-results && npm run house-ads:verify-brand-domain -- --max-brands=500 --skip-network=true && npm run house-ads:crawl-brand-pages -- --max-brands=500 --max-pages-per-brand=2 && npm run house-ads:generate-creatives -- --max-brands=500 && npm run house-ads:qa-and-publish -- --min-brands=500",
    "house-ads:offers:build-jobs": "node ./scripts/house-ads/build-offer-jobs.js",
    "house-ads:offers:crawl": "node ./scripts/house-ads/crawl-offers.js --concurrency=120 --max-pages-per-brand=1 --max-attempts-per-brand=1 --timeout-ms=1800 --max-candidates-per-brand=3",
    "house-ads:offers:normalize": "node ./scripts/house-ads/normalize-offers.js",
    "house-ads:offers:synthesize": "node ./scripts/house-ads/synthesize-offers.js --fill-mode=missing --min-product-offers=6",
    "house-ads:offers:merge": "node ./scripts/house-ads/merge-offers.js",
    "house-ads:offers:qa": "node ./scripts/house-ads/qa-offers.js --source-policy=real_only --image-hard-gate=true --sensitive-block=true",
    "house-ads:offers:publish": "node ./scripts/house-ads/publish-offer-creatives.js",
    "house-ads:offers:publish:supabase": "node --env-file-if-exists=.env ./scripts/house-ads/publish-offers-to-supabase.js --sync-inventory=true --sync-scope=full",
    "house-ads:offers:bootstrap": "npm run house-ads:offers:build-jobs && npm run house-ads:offers:crawl && npm run house-ads:offers:normalize && npm run house-ads:offers:synthesize && npm run house-ads:offers:merge && npm run house-ads:offers:qa && npm run house-ads:offers:publish",
    "inventory:sync:partnerstack": "node --env-file-if-exists=.env ./scripts/inventory/sync-partnerstack.js",
    "inventory:sync:cj": "node --env-file-if-exists=.env ./scripts/inventory/sync-cj.js",
    "inventory:sync:house": "node --env-file-if-exists=.env ./scripts/inventory/sync-house.js",
    "inventory:health:links": "node ./scripts/inventory/health-links.js",
    "inventory:health:images": "node ./scripts/inventory/health-images.js",
    "inventory:coverage:products": "node ./scripts/inventory/coverage-products.js",
    "inventory:coverage:categories": "node ./scripts/inventory/coverage-categories.js",
    "inventory:embeddings": "node --env-file-if-exists=.env ./scripts/inventory/build-embeddings.js",
    "inventory:embeddings:full": "node --env-file-if-exists=.env ./scripts/inventory/rebuild-embeddings-full.js",
    "inventory:snapshot": "node --env-file-if-exists=.env ./scripts/inventory/materialize-serving-snapshot.js",
    "budget:backfill:dry-run": "node --env-file-if-exists=.env ./scripts/budget/backfill-campaign-budgets.js --mode=dry-run",
    "budget:backfill:apply": "node --env-file-if-exists=.env ./scripts/budget/backfill-campaign-budgets.js --mode=apply",
    "budget:coverage:report": "node --env-file-if-exists=.env ./scripts/budget/backfill-campaign-budgets.js --mode=report",
    "inventory:sync:all": "npm run inventory:sync:partnerstack && npm run inventory:sync:cj && npm run inventory:sync:house && npm run inventory:embeddings && npm run inventory:snapshot",
    "inventory:report:dialogues": "node ./scripts/pilot/generate-product-dialogue-report.js",
    "relevance:calibrate": "node --env-file-if-exists=.env ./scripts/relevance-calibration.js",
    "pilot:content:enrich": "node --env-file-if-exists=.env ./scripts/pilot/enrich-content-cases.js",
    "content:enrich:full": "node --env-file-if-exists=.env ./scripts/pilot/enrich-content-full.js",
    "content:enrich:report": "node --env-file-if-exists=.env ./scripts/pilot/generate-content-enrichment-report.js",
    "content:enrich:report:combined": "node --env-file-if-exists=.env ./scripts/pilot/generate-content-enrichment-combined-report.js",
    "content:enrich:api-samples": "node --env-file-if-exists=.env ./scripts/pilot/fetch-content-api-samples.js",
    "pilot:content:reindex": "npm run inventory:embeddings:full && npm run inventory:snapshot",
    "pilot:content:api-samples": "node --env-file-if-exists=.env ./scripts/pilot/fetch-api-samples.js",
    "pilot:content:review-pack": "node ./scripts/pilot/generate-review-pack.js"
  },
  "dependencies": {
    "pg": "^8.16.3"
  }
}
